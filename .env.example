OPENAI_API_KEY= <your openai api key> # required
# optional:
OPENCLAW_MODE=cli
OPENCLAW_CMD=openclaw
OPENCLAW_SESSION_ID=ghost-orchestrator
OPENCLAW_PROFILE=
OPENCLAW_TIMEOUT_MS=90000
OPENAI_MODEL=gpt-4o-mini # or any other openai model
GOOGLE_SHEET_ID= <your google sheet id>
GOOGLE_SHEET_RANGE= <your google sheet range(tab name and columns)>
GOOGLE_SERVICE_ACCOUNT_KEY_B64= <your google service account key base64 encoded>